---
import { Picture } from "astro:assets";

import footer1 from "../assets/images/portfolio/port1.jpg";
import footer2 from "../assets/images/portfolio/port2.jpg";
import footer3 from "../assets/images/portfolio/port3.jpg";
---

<footer id="cs-footer">

  <!-- ── TOP CTA AREA ─────────────────────────────── -->
  <div class="cs-container">
    <div class="cs-cta-row">

      <!-- Left: text + button -->
      <div class="cs-cta-text">
        <h2 class="cs-title">
         Ready to become the most recognized solar installer in your market? Let's build something that lasts.
        </h2>
        <!-- Reusing the global solid button class for consistency -->
        <a href="/contact" class="cs-button-solid">Talk to Us</a>
      </div>

      <!-- Right: CSS crossfade slideshow -->
      <div class="cs-slideshow-wrapper">
        <div class="cs-slideshow">
          <!-- Slide 1 -->
          <div class="cs-slide cs-slide--1">
            <Picture
              src={footer1}
              alt="Interior design project one"
              formats={["avif", "webp"]}
              pictureAttributes={{ class: "cs-slide-picture" }}
            />
          </div>
          <!-- Slide 2 -->
          <div class="cs-slide cs-slide--2">
            <Picture
              src={footer2}
              alt="Interior design project two"
              formats={["avif", "webp"]}
              pictureAttributes={{ class: "cs-slide-picture" }}
            />
          </div>
          <!-- Slide 3 -->
          <div class="cs-slide cs-slide--3">
            <Picture
              src={footer3}
              alt="Interior design project three"
              formats={["avif", "webp"]}
              pictureAttributes={{ class: "cs-slide-picture" }}
            />
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── BOTTOM: LINE / COPYRIGHT / SOCIALS ───────── -->
  <div class="cs-bottom">
    <div class="cs-bottom-inner">

      <p class="cs-copyright">Copyright CHASE</p>

      <ul class="cs-social-list">
        <!-- Instagram -->
        <li class="cs-social-item">
          <a href="#" class="cs-social-link" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
        </li>

        <!-- Twitter / X -->
        <li class="cs-social-item">
          <a href="#" class="cs-social-link" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </li>

        <!-- Facebook -->
        <li class="cs-social-item">
          <a href="#" class="cs-social-link" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </li>

        <!-- Behance -->
        <li class="cs-social-item">
          <a href="#" class="cs-social-link" aria-label="Behance">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.5 11.5c1.38 0 2.5-.9 2.5-2.25S8.88 7 7.5 7H3v10h4.8c1.5 0 2.7-1.02 2.7-2.5 0-1.3-.9-2.28-3-3zm-.3 4H5.1v-2.5H7c.97 0 1.5.5 1.5 1.25S8.2 15.5 7.2 15.5zM5.1 9h1.9c.83 0 1.4.45 1.4 1.2S7.83 11.4 7 11.4H5.1V9zm9.55 1.25c-2.07 0-3.65 1.5-3.65 3.75s1.58 3.75 3.65 3.75c1.63 0 2.8-.82 3.35-2.1h-1.7c-.28.5-.9.82-1.65.82-1.03 0-1.75-.65-1.87-1.72H22v-.6c0-2.3-1.5-3.9-3.55-3.9zM13.1 14c.2-1 .87-1.5 1.75-1.5s1.52.52 1.68 1.5H13.1zM17.5 7h-4v1.2h4V7z"/>
            </svg>
          </a>
        </li>
      </ul>

    </div>
  </div>
</footer>

<style lang="less">
/*-- -------------------------- -->
<---           Footer           -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0em) {
  #cs-footer {
    /* Using global padding to keep it perfectly aligned with other sections */
    padding: var(--sectionPadding);
    /* Removes the bottom padding so the line sits correctly */
    padding-bottom: 0;
    background-color: #000;
    color: #fff;

    /* ---- Shared container ---- */
    .cs-container {
      width: 100%;
      max-width: (1280/16rem);
      margin: 0 auto;
    }

    /* ── CTA ROW ── */
    .cs-cta-row {
      display: flex;
      flex-direction: column;
      gap: clamp(2.5rem, 6vw, 4rem);
    }

    /* ── LEFT: TEXT BLOCK ── */
    .cs-cta-text {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: (28/16rem);
    }

    .cs-title {
      color: #fff;
      margin: 0;
      text-align: left;
      max-width: (560/16rem);
    }

    /* ── OVERRIDING THE GLOBAL BUTTON ── */
    .cs-button-solid {
      background-color: #a8e5a3;
      color: #000;
      margin: 0;
      /* Remove border radius if you want it square, or leave it */
      border-radius: (4/16rem);

      &:before {
        /* Makes the hover slide effect white */
        background-color: #fff;
      }

      &:hover {
        color: #000;
      }
    }

    /* ── SLIDESHOW WRAPPER ── */
    .cs-slideshow-wrapper {
      width: 100%;
      /* Fluid height on mobile */
      height: clamp(18.75rem, 60vw, 25rem);
      border-radius: (12/16rem);
      overflow: hidden;
      position: relative;
    }

    /* ── SLIDESHOW: position stack ── */
    .cs-slideshow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    /* Each slide stacks absolutely on top of the others */
    .cs-slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      /* 6 seconds total. Linear fade ensures a perfect blend */
      animation: cs-fade 6s infinite;

      &.cs-slide--1 { animation-delay: 0s; }
      &.cs-slide--2 { animation-delay: 2s; }
      &.cs-slide--3 { animation-delay: 4s; }

      .cs-slide-picture {
        display: block;
        width: 100%;
        height: 100%;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
      }
    }

    /* ── BOTTOM BAR ── */
    .cs-bottom {
      width: 100%;
      margin-top: clamp(3.5rem, 8vw, 6rem);
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .cs-bottom-inner {
      width: 100%;
      max-width: (1280/16rem);
      margin: 0 auto;
      padding: (24/16rem) 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: (20/16rem);
    }

    .cs-copyright {
      font-size: (14/16rem);
      color: rgba(255,255,255,0.65);
      margin: 0;
      text-transform: uppercase;
    }

    /* ── SOCIAL LIST ── */
    .cs-social-list {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: (8/16rem);
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .cs-social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: (40/16rem);
      height: (40/16rem);
      background-color: transparent;
      border-radius: 50%;
      color: rgba(255,255,255,0.7);
      transition: color 0.3s ease, background-color 0.3s;

      svg {
        width: (20/16rem);
        height: auto;
        display: block;
      }

      &:hover {
        color: #000;
        background-color: #a8e5a3;
      }
    }
  }

  /* Tablet - 768px */
  @media only screen and (min-width: 48rem) {
    #cs-footer {
      .cs-cta-row {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }

      .cs-cta-text {
        width: 45%;
        /* Stops flexbox from squishing the text */
        flex: none;
      }

      .cs-slideshow-wrapper {
        width: 50%;
        /* Fixed height on tablet/desktop */
        height: (400/16rem);
        flex: none;
      }

      /* ── Bottom bar: copyright left, socials right ── */
      .cs-bottom-inner {
        flex-direction: row;
        justify-content: space-between;
      }
    }
  }

  /* ── Crossfade keyframes ────────────────────────── */
  /*
     With 3 images and a 6s loop:
     1/3 of the time (33.33%) the image is fully visible.
     We want it to hold, then fade out smoothly.
  */
  @keyframes cs-fade {
    0% { opacity: 1; }
    25% { opacity: 1; }      /* Hold visibility for 1.5 seconds */
    33.33% { opacity: 0; }   /* Fade out over 0.5 seconds */
    91.66% { opacity: 0; }   /* Stay hidden while other 2 slides play */
    100% { opacity: 1; }     /* Fade back in to perfectly loop to 0% */
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .cs-slide {
      animation: none;
      &.cs-slide--1 { opacity: 1; }
      &.cs-slide--2 { opacity: 0; }
      &.cs-slide--3 { opacity: 0; }
    }
  }
}
</style>