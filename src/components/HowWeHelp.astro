---
import { Picture } from "astro:assets";
import whatWeDoImage from "../assets/images/what-we-do.jpg";

const services = [
  {
    title: "Turn Your Social Media Into Your Best Salesperson",
    list: [
      "Attract serious buyers already thinking about solar",
      "Build the trust that converts followers into clients",
      "Stand out in a crowded, competitive market"
    ],
    image: whatWeDoImage,
    inverted: false // Image on the LEFT
  },
  {
    title: "Get in Front of People Already Looking for What You Offer",
    list: [
      "Highly targeted ads across Meta & TikTok",
      "Reach homeowners and businesses actively researching solar",
      "Every naira spent working toward a real lead."
    ],
    image: whatWeDoImage,
    inverted: true // Image on the RIGHT
  },
  {
    title: "A Website That Earns Trust Before You Say a Word",
    list: [
      "Portfolio that showcases your best projects beautifully",
      "Built to capture and convert visitor interest into inquiries",
      "Amplifies your ads and social — everything points here"
    ],
    image: whatWeDoImage,
    inverted: false // Image on the LEFT
  }
];
---

<!-- ============================================ -->
<!--                 Side By Side                 -->
<!-- ============================================ -->

<section id="sbs-2373">
    <div class="cs-container">
        <div class="cs-content">

            <h2 class="cs-title">We Build Your Business, Not Just Your Campaign</h2>

        </div>

        <!-- The React-style Loop -->
        {services.map((service) => (
            <div class:list={["cs-flex", { "cs-inverted": service.inverted }]}>
                <div class="cs-content2">
                    <h3 class="cs-h3">{service.title}</h3>
                    <ul class="cs-ul">
                        {service.list.map((item) => (
                            <li class="cs-li">
                                <img class="cs-icon" aria-hidden="true" loading="lazy" decoding="async" src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/swirl.svg" alt="checkmark" width="28" height="28">
                                {item}
                            </li>
                        ))}
                    </ul>
                </div>

                <Picture
                    src={service.image}
                    alt={service.title}
                    formats={['avif', 'webp']}
                    pictureAttributes={{ class: "cs-picture" }}
                />
            </div>
        ))}

    </div>
</section>

<style lang="less">
/*-- -------------------------- -->
<---       Side By Side         -->
<--- -------------------------- -*/

/* Mobile */
@media only screen and (min-width: 0rem) {
  #sbs-2373 {
    padding: var(--sectionPadding);
    background-color: #ffffff; /* Clean white background */
    box-sizing: border-box;

    .cs-container {
      width: 100%;
      max-width: (1280/16rem);
      margin: auto;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      /* Gap between the blocks */
      gap: clamp(3rem, 8vw, 6rem);
    }

    .cs-content {
      text-align: center;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .cs-title {
      margin: 0;
    }

    .cs-content2 {
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .cs-flex {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      /* Space between text and image on mobile */
      gap: clamp(1.5rem, 4vw, 3rem);
    }

    .cs-h3 {
      /* 24px - 32px */
      font-size: clamp(1.5rem, 3vw, 2rem);
      line-height: 1.2em;
      font-weight: 700;
      /* Smaller margin since the paragraph is gone */
      margin: 0 0 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid #D2D8DF;
      color: var(--headerColor);
    }

    .cs-ul {
      width: 100%;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem; /* Increased gap for readability */
    }

    .cs-li {
      /* Significantly larger text for readability */
      font-size: clamp(1.125rem, 2vw, 1.25rem);
      list-style: none;
      line-height: 1.5em;
      width: 100%;
      color: var(--bodyTextColor);
      display: flex;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .cs-icon {
      /* Slightly larger icon to match the bigger text */
      width: 1.5rem;
      height: auto;
      margin-top: 2px;
      display: block;
      flex: none;
    }

    .cs-picture {
      width: 100%;
      height: 75vw;
      max-height: 25rem; /* Slightly taller to look better next to larger text */
      border-radius: 1rem;
      overflow: hidden;
      display: block;
      /* Forces image to the top on mobile */
      order: -1;
      position: relative;
      z-index: 1;

      img {
        width: 100%;
        height: 100%;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        object-fit: cover;
      }
    }
  }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
  #sbs-2373 {
    .cs-flex {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;

      /* INVERTED LAYOUT LOGIC */
      &.cs-inverted {
        .cs-picture {
          /* Pushes the image to the right */
          order: 2;
        }
        .cs-content2 {
          /* Pushes the text to the left */
          order: 1;
        }
      }
    }

    .cs-content2 {
      width: 48%; /* Text takes up a bit less than half */
    }

    .cs-picture {
      width: 45%;
      max-width: 35rem;
      /* Let height conform to image aspect ratio or max-height */
      height: 100%;
      min-height: 25rem;
    }
  }
}
</style>